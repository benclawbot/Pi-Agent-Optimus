{
  "defaultProvider": "minimax",
  "defaultModel": "MiniMax/M2.7",
  "defaultThinkingLevel": "off",
  "hideThinkingBlock": true,
  "theme": "dark",
  "shellCommandPrefix": "shopt -s expand_aliases",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 8192,
    "keepRecentTokens": 15000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 2
  },
  "skills": [
    "~/.pi/agent/skills/startup",
    "~/.pi/agent/skills/quick-ref",
    "~/.pi/agent/skills/commit",
    "~/.pi/agent/skills/caveman",
    "~/.pi/agent/skills/skill-evolution",
    "~/.pi/agent/skills/project-health",
    "~/.pi/agent/skills/system-awareness",
    "~/.pi/agent/skills/auto-test",
    "~/.pi/agent/skills/file-watcher",
    "~/.pi/agent/skills/ci-watcher",
    "~/.pi/agent/skills/architecture-diagram",
    "~/.pi/agent/skills/scheduler",
    "~/.pi/agent/skills/db-introspect",
    "~/.pi/agent/skills/auto-recover",
    "~/.pi/agent/skills/context-memory",
    "~/.pi/agent/skills/proactive-context",
    "~/.pi/agent/skills/quick-context",
    "~/.pi/agent/skills/skill-chain",
    "~/.pi/agent/skills/improvement-tracker",
    "~/.pi/agent/skills/task-continuity",
    "~/.pi/agent/skills/decision-tracker",
    "~/.pi/agent/skills/daily-standup",
    "~/.pi/agent/skills/quick-project-switch",
    "~/.pi/agent/skills/task-linker",
    "~/.pi/agent/skills/intent-classifier",
    "~/.pi/agent/skills/memory-summarizer",
    "~/.pi/agent/skills/tech-stack-detector",
    "~/.pi/agent/skills/skill-marketplace",
    "~/.pi/agent/skills/skill-memory-sharing",
    "~/.pi/agent/skills/chain-of-thought",
    "~/.pi/agent/skills/self-optimization-loop"
  ],
  "enableSkillCommands": true,
  "extensions": [
    "+extensions/btw/index.ts",
    "+extensions/reload/index.ts",
    "+extensions/todos/index.ts"
  ],
  "lastChangelogVersion": "0.74.0",
  "terminal": {
    "showTerminalProgress": false
  }
}
